# =============================================
# .env.example — Variables de entorno RepFora
# =============================================
# INSTRUCCIONES:
#   Windows (PowerShell):  Copy-Item .env.example .env
#   Mac/Linux:             cp .env.example .env
#
# Luego edita .env con los valores reales.
# ⚠️  El archivo .env NUNCA se sube a GitHub (está en .gitignore).
# =============================================

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Base de datos (MongoDB Atlas) ---
# Pide la URI completa al lider del proyecto (DEV 1 - Santiago)
# Ejemplo local:  mongodb://localhost:27017/repfora_db
# Ejemplo Atlas:  mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/repfora_db
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/repfora_db?retryWrites=true&w=majority&appName=Cluster0

# --- Autenticacion JWT (DEV 1) ---
# Pide la clave JWT al lider del proyecto (DEV 1 - Santiago)
JWT_SECRET=coloca_aqui_el_secreto_jwt_minimo_32_caracteres
JWT_EXPIRES_IN=8h

# --- Frontend (CORS) ---
# URL donde corre el frontend en desarrollo
FRONTEND_URL=http://localhost:5173

# --- Email SMTP (DEV 1 - Recuperacion de contraseña) ---
# Credenciales de Gmail gestionadas por DEV 1 (Santiago)
# Si no trabajas con emails, puedes dejar estos en blanco sin problema
# Crea un App Password en: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
SMTP_FROM=RepFora SENA <tu_correo@gmail.com>

# --- Google Drive (DEV 2 - Modulo de Documentos) ---
# Esta seccion es responsabilidad de DEV 2.
# Si no configuras Drive, el servidor funciona en modo simulado
# (las URLs de archivos tendran el prefijo "dev_" en lugar de ser reales).
#
# OPCION A (recomendada en desarrollo):
#   1. Ve a Google Cloud Console y descarga el JSON de la cuenta de servicio
#   2. Coloca el archivo en: backend/credentials/google-service-account.json
#   (La carpeta credentials/ esta protegida en .gitignore)
GOOGLE_CREDENTIALS_PATH=./credentials/google-service-account.json
#
# OPCION B (para produccion / sin archivos locales):
#   Copia todo el contenido del JSON en una sola linea
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ID de la carpeta raiz del proyecto en Google Drive
# Crea una carpeta en Drive y copia el ID de la URL:
# https://drive.google.com/drive/folders/  <-- ESTE_ES_EL_ID
GOOGLE_DRIVE_FOLDER_ID=pega_aqui_el_id_de_la_carpeta_raiz_en_drive
