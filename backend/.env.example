# =============================================
# .env.example — Variables de entorno RepFora
# =============================================
# Copia este archivo como .env y rellena los valores.
# ⚠️  NUNCA subas tu .env real a Git.
# =============================================

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Base de datos (MongoDB Atlas) ---
# Pide la URI al lider del proyecto (DEV 1 - Santiago)
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/repfora_db?retryWrites=true&w=majority&appName=Cluster0

# --- Autenticacion JWT ---
# Pide la clave JWT al lider del proyecto (DEV 1 - Santiago)
JWT_SECRET=coloca_aqui_el_secreto_jwt
JWT_EXPIRES_IN=8h

# --- Frontend (CORS) ---
# URL donde corre el frontend en desarrollo
FRONTEND_URL=http://localhost:5173

# --- Email (SMTP - Gmail) ---
# Las credenciales de Gmail pertenecen a DEV 1 (Santiago)
# Si solo vas a trabajar el backend sin emails, puedes dejar estos en blanco
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=correo@gmail.com
SMTP_PASS=clave_de_aplicacion_gmail_16_letras
SMTP_FROM=RepFora SENA <correo@gmail.com>

# --- Google Drive (DEV 2 - Subida de documentos) ---
# Esta seccion es responsabilidad de DEV 2
# Si no configuras Drive, el servidor funciona igual pero en modo simulado
# (las URLs de archivos seran falsas con prefijo "dev_")

# OPCION A (recomendada en desarrollo):
# Descarga el JSON de cuenta de servicio de Google Cloud Console
# y ponlo en: backend/credentials/google-service-account.json
GOOGLE_CREDENTIALS_PATH=./credentials/google-service-account.json

# OPCION B (alternativa para produccion sin archivos):
# Copia todo el contenido del JSON de credenciales en una sola linea
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ID de la carpeta raiz del proyecto en Google Drive
# Crea una carpeta en Drive, entrala, y copia el ID de la URL:
# https://drive.google.com/drive/folders/ESTE_ES_EL_ID
GOOGLE_DRIVE_FOLDER_ID=pega_aqui_el_id_de_carpeta_drive
