# =============================================
# Variables de entorno - RepFora Backend
# =============================================

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Base de datos ---
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/repfora_db
DATABASE_URL=postgresql://usuario:password@localhost:5432/repfora

# --- Autenticacion ---
JWT_SECRET=tu_clave_secreta_aqui
JWT_EXPIRES_IN=8h

# --- Google Drive (DEV 2 - Modulo 3) ---
# Opcion A: Ruta al archivo JSON de credenciales de cuenta de servicio
GOOGLE_CREDENTIALS_PATH=./credentials/google-service-account.json

# Opcion B: JSON completo de credenciales (para produccion/CI)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ID de la carpeta raiz del proyecto en Google Drive
GOOGLE_DRIVE_FOLDER_ID=tu_id_de_carpeta_raiz_aqui

# --- Frontend ---
FRONTEND_URL=http://localhost:5173
