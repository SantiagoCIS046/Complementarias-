# =============================================
# Variables de entorno - RepFora Backend
# =============================================
# INSTRUCCIONES: Copia este archivo como .env y rellena los valores reales.
#
#   Windows (PowerShell):  Copy-Item .env.example .env
#   Mac/Linux:             cp .env.example .env
#
# El archivo .env NO se sube a GitHub (está en .gitignore).
# =============================================

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Base de datos (MongoDB) ---
# Ejemplo local:    mongodb://localhost:27017/repfora_db
# Ejemplo Atlas:    mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/repfora_db
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/repfora_db

# --- Autenticacion (DEV 1) ---
JWT_SECRET=tu_clave_secreta_aqui_min_32_chars
JWT_EXPIRES_IN=8h

# --- Correo / SMTP (DEV 1 - Recuperacion de contrasena) ---
# Crea un App Password en: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
SMTP_FROM=tu_correo@gmail.com

# --- Google Drive (DEV 2 - Modulo de Documentos) ---
# Opcion A: Ruta al archivo JSON de la cuenta de servicio (recomendado en desarrollo)
#   Coloca el archivo en: backend/src/core/config/credentials.json
GOOGLE_CREDENTIALS_PATH=./src/core/config/credentials.json
# Opcion B: JSON completo inline (recomendado en CI/produccion)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# ID de la carpeta raiz del proyecto en Google Drive
GOOGLE_DRIVE_FOLDER_ID=tu_id_de_carpeta_raiz_aqui

# --- Frontend ---
FRONTEND_URL=http://localhost:5173
