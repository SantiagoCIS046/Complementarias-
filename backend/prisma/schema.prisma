// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

// Modelos básicos para RepFora

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  role      String   @default("APRENDIZ")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  nit       String   @unique
  address   String?
  contact   String?
  createdAt DateTime @default(now())
}

model ProductiveStage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  apprenticeId String   @db.ObjectId
  status      String   @default("POR_INICIAR")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
}

model Bitacora {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  stageId   String   @db.ObjectId
  number    Int
  content   String?
  status    String   @default("PENDIENTE")
  createdAt DateTime @default(now())
}
