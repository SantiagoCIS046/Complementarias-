// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modelos básicos para RepFora

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("APRENDIZ") // ADMIN, INSTRUCTOR, APRENDIZ, EMPRESA
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  nit       String   @unique
  address   String?
  contact   String?
  createdAt DateTime @default(now())
}

model ProductiveStage {
  id          Int      @id @default(autoincrement())
  apprenticeId Int
  status      String   @default("POR_INICIAR")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
}

model Bitacora {
  id        Int      @id @default(autoincrement())
  stageId   Int
  number    Int
  content   String?
  status    String   @default("PENDIENTE")
  createdAt DateTime @default(now())
}
